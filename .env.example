# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# .env is gitignored; this template is safe to commit.

# --- Required ---
# Your OpenAI API key (https://platform.openai.com/api-keys).
# Required even when answering with Claude, because the "auto" router uses an
# OpenAI classifier model.
OPENAI_API_KEY=sk-your-key-here

# --- Optional: Anthropic / Claude ---
# Only needed if you point a tier below at a Claude model (any model whose name
# starts with "claude", e.g. claude-sonnet-5). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Optional: other providers (via LiteLLM) ---
# A tier may also be a provider-prefixed model routed through LiteLLM, e.g.
#   OPENAI_MODEL_SMART=gemini/gemini-flash-latest   (use the -latest aliases;
#                                                    dated Gemini IDs may be gated)
#   OPENAI_MODEL_SMART=mistral/mistral-large-latest
#   OPENAI_MODEL_SMART=bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
# Set that provider's standard credential (uncomment what you use):
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# Bedrock uses AWS credentials and also requires `pip install boto3`:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION_NAME=us-east-1

# --- Model routing ---
# The orchestrator routes each request to a tier based on task difficulty.
# For the router to be effective, these MUST point at genuinely different
# models — otherwise routing is a no-op that only adds a classifier call.
# Any tier below may be a Claude model (e.g. OPENAI_MODEL_SMART=claude-sonnet-5)
# or a LiteLLM provider-prefixed model (gemini/..., bedrock/..., mistral/..., etc.);
# it is dispatched automatically. The router itself must stay an OpenAI model.

# Base/default model. Used as the fallback default if a tier below is unset.
OPENAI_MODEL=gpt-5

# Cheap, fast classifier used in "auto" mode to pick a tier. Keep this small.
OPENAI_MODEL_ROUTER=gpt-5-nano

# Simple tasks (quick facts, chat, summaries, reformatting). Cheaper/faster.
OPENAI_MODEL_FAST=gpt-5-mini

# Hard tasks (coding, debugging, reasoning, planning, math, analysis).
OPENAI_MODEL_SMART=gpt-5

# Used only when the primary model call fails. Should differ from the primary
# so a model-specific outage can actually fall back.
OPENAI_MODEL_FALLBACK=gpt-5-mini

# --- Token budgets (optional) ---
# Max output tokens per tier. These include model reasoning tokens, so they
# need headroom. Defaults shown.
FAST_MAX_OUTPUT_TOKENS=1500
SMART_MAX_OUTPUT_TOKENS=4000

# --- Per-task-category models (optional) ---
# The heart of the orchestrator: in "auto" mode the router classifies each
# request into a task category, and if that category has a model set here, the
# request goes to it (across any provider) — otherwise it uses the fast/smart
# tier above. This is how you send each kind of task to the model best at it.
# The tier (fast/smart) still sets the token budget + reasoning effort.
# Categories: quick_fact, casual_chat, summarization, simple_transform,
#             coding, debugging, reasoning, planning, math, analysis, creative_writing
# These can also be edited at runtime from the app's Settings panel (or the
# /v1/settings API) without restarting; a value saved there overrides the
# matching env var below. See ALLOW_SETTINGS_WRITE to lock that down.
#
# A strong "best model per task" starting point (needs the matching keys above;
# uncomment and edit to taste). Anything left unset uses the fast/smart tier.
#   Claude for code + reasoning + writing:
# MODEL_CODING=claude-sonnet-5
# MODEL_DEBUGGING=claude-sonnet-5
# MODEL_REASONING=claude-sonnet-5
# MODEL_PLANNING=claude-sonnet-5
# MODEL_CREATIVE_WRITING=claude-sonnet-5
#   OpenAI for math + analysis:
# MODEL_MATH=gpt-5
# MODEL_ANALYSIS=gpt-5
#   Fast + free for trivial tasks:
# MODEL_QUICK_FACT=groq/llama-3.3-70b-versatile
# MODEL_CASUAL_CHAT=groq/llama-3.3-70b-versatile
# MODEL_SUMMARIZATION=gemini/gemini-flash-lite-latest
# MODEL_SIMPLE_TRANSFORM=gemini/gemini-flash-lite-latest

# --- Cost estimates (optional) ---
# Each answer reports tokens used and an estimated USD cost. Prices are built in
# for the common models (approximate — they change often). Override or add
# prices with a JSON map of {"model": [usd_per_1M_input, usd_per_1M_output]}:
# MODEL_PRICING={"gpt-5": [1.25, 10.0], "claude-sonnet-5": [3.0, 15.0]}

# --- Response cache (optional) ---
# Cache answers so an identical prompt (same mode + model config) returns
# instantly and for free, with no model call. Set to "false" to disable.
RESPONSE_CACHE=true
# Entry lifetime in seconds; 0 (default) means entries never expire.
RESPONSE_CACHE_TTL_SECONDS=0
# Max stored entries before the least-recently-used are evicted (0 = unbounded).
RESPONSE_CACHE_MAX_ENTRIES=1000

# --- Conversation memory (optional) ---
# Long conversations keep the most recent 12 turns verbatim; everything older is
# folded into a compact summary (one cheap OPENAI_MODEL_ROUTER call before the
# answer) so the model keeps the whole thread's context instead of forgetting it.
# Short conversations (<= 12 prior messages) are untouched and make no extra call.
SUMMARIZE_HISTORY=true
# Max tokens for that summary. Default shown.
SUMMARY_MAX_OUTPUT_TOKENS=600

# --- Reasoning effort (optional) ---
# Per-tier reasoning effort: minimal|low|medium|high. Lower effort makes the
# fast tier answer simple questions much faster. Invalid values fall back to
# the defaults shown.
FAST_REASONING_EFFORT=low
SMART_REASONING_EFFORT=medium

# --- Timeouts (optional) ---
# Per-request timeout for OpenAI answer calls, in seconds. Default shown.
OPENAI_TIMEOUT_SECONDS=120

# --- API auth (optional) ---
# Static bearer token required on /v1/ask and /v1/conversations* endpoints.
# Leave empty to disable static-token auth.
API_AUTH_TOKEN=

# --- User accounts / JWT auth (optional) ---
# Set a signing secret to enable username/password accounts. When set,
# /v1/auth/register and /v1/auth/login become active and JWTs they issue are
# accepted on the protected endpoints (alongside API_AUTH_TOKEN, if also set).
# When logged in via JWT, each user's conversations are private to them; with
# auth off or a static token they share one unowned bucket.
JWT_SECRET=
# Access-token lifetime in minutes (default 60).
JWT_EXPIRE_MINUTES=60
# Set to "false" to disable the /v1/auth/register endpoint.
ALLOW_REGISTRATION=true

# --- Settings API (optional) ---
# The task->model map is editable at runtime via the Settings panel / the
# /v1/settings endpoints (a saved value overrides the matching env var above).
# The map is GLOBAL, so on a shared/multi-user deployment set this to "false" to
# make the settings read-only (writes return 403); edits then come only from env.
ALLOW_SETTINGS_WRITE=true

# --- CORS (optional) ---
# Comma-separated list of allowed browser origins. Default shown.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Rate limiting (optional) ---
# Per-client-IP limit on the ask endpoints, in slowapi syntax (e.g. "60/minute",
# "5/second"). Leave empty to disable rate limiting entirely.
RATE_LIMIT=
# Set "true" ONLY when the backend runs behind a trusted reverse proxy that sets
# X-Forwarded-For (e.g. the bundled docker-compose nginx). Then the rate-limit
# key is the forwarded client IP instead of the proxy's. Do not enable if the
# backend is reachable directly — clients could spoof the header.
TRUST_PROXY_HEADERS=false

# --- Observability (optional) ---
# OpenTelemetry tracing is off unless an OTLP/HTTP endpoint is set here. Point it
# at any OTLP collector (SigNoz, Grafana Tempo, Jaeger, an OTel Collector, ...).
# Traces include per-request spans enriched with the routing decision
# (ai.mode_used, ai.model, ai.provider).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ai-orchestrator

# --- Storage (optional) ---
# SQLite database path. Defaults to ai_orchestrator.db in the project root.
DATABASE_PATH=ai_orchestrator.db
