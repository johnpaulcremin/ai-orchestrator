# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# .env is gitignored; this template is safe to commit.

# --- Required ---
# Your OpenAI API key (https://platform.openai.com/api-keys).
# Required even when answering with Claude, because the "auto" router uses an
# OpenAI classifier model.
OPENAI_API_KEY=sk-your-key-here

# --- Optional: Anthropic / Claude ---
# Only needed if you point a tier below at a Claude model (any model whose name
# starts with "claude", e.g. claude-sonnet-5). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Model routing ---
# The orchestrator routes each request to a tier based on task difficulty.
# For the router to be effective, these MUST point at genuinely different
# models — otherwise routing is a no-op that only adds a classifier call.
# Any tier below may be a Claude model (e.g. OPENAI_MODEL_SMART=claude-sonnet-5);
# it is dispatched to Anthropic automatically. The router must stay an OpenAI model.

# Base/default model. Used as the fallback default if a tier below is unset.
OPENAI_MODEL=gpt-5

# Cheap, fast classifier used in "auto" mode to pick a tier. Keep this small.
OPENAI_MODEL_ROUTER=gpt-5-nano

# Simple tasks (quick facts, chat, summaries, reformatting). Cheaper/faster.
OPENAI_MODEL_FAST=gpt-5-mini

# Hard tasks (coding, debugging, reasoning, planning, math, analysis).
OPENAI_MODEL_SMART=gpt-5

# Used only when the primary model call fails. Should differ from the primary
# so a model-specific outage can actually fall back.
OPENAI_MODEL_FALLBACK=gpt-5-mini

# --- Token budgets (optional) ---
# Max output tokens per tier. These include model reasoning tokens, so they
# need headroom. Defaults shown.
FAST_MAX_OUTPUT_TOKENS=1500
SMART_MAX_OUTPUT_TOKENS=4000

# --- Reasoning effort (optional) ---
# Per-tier reasoning effort: minimal|low|medium|high. Lower effort makes the
# fast tier answer simple questions much faster. Invalid values fall back to
# the defaults shown.
FAST_REASONING_EFFORT=low
SMART_REASONING_EFFORT=medium

# --- Timeouts (optional) ---
# Per-request timeout for OpenAI answer calls, in seconds. Default shown.
OPENAI_TIMEOUT_SECONDS=120

# --- API auth (optional) ---
# Bearer token required on /v1/ask and /v1/conversations* endpoints.
# Leave empty to disable auth entirely (no token required).
API_AUTH_TOKEN=

# --- CORS (optional) ---
# Comma-separated list of allowed browser origins. Default shown.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Rate limiting (optional) ---
# Per-client-IP limit on the ask endpoints, in slowapi syntax (e.g. "60/minute",
# "5/second"). Leave empty to disable rate limiting entirely.
RATE_LIMIT=

# --- Storage (optional) ---
# SQLite database path. Defaults to ai_orchestrator.db in the project root.
DATABASE_PATH=ai_orchestrator.db
